// ── TUBEL MENU (3-level) ──────────────────────────────────────────
function handleTubelMenu(userId, input, subState) {

    // Level 1: pilih STAN / BPKP
    if (!subState) {
        switch (input) {
            case '1':
                setUserState(userId, STATE.TUBEL_MENU, 'STAN');
                return {
                    text: MENUS.TUBEL_STAN,
                    file: 'Tubel STAN Class 2026.pdf',
                    fileName: 'Tubel STAN Class 2026.pdf',
                    fileCaption: '📎 *Info lengkap Tubel STAN Class 2026*\nSetelah extra disc: Rp 799.000 🔥'
                };
            case '2':
                setUserState(userId, STATE.TUBEL_MENU, 'BPKP');
                return { text: MENUS.TUBEL_BPKP };
            case '3':
                return CONTENT.LIVE_AGENT;
            default:
                return { text: MENUS.TUBEL };
        }
    }

    // Level 2: STAN → pilih Kelas / TO
    if (subState === 'STAN') {
        switch (input) {
            case '1':
                setUserState(userId, STATE.TUBEL_MENU, 'STAN_KELAS');
                return { text: MENUS.TUBEL_STAN_KELAS };
            case '2':
                setUserState(userId, STATE.TUBEL_MENU, 'STAN_TO');
                return { text: MENUS.TUBEL_STAN_TO };
            case '3':
                return CONTENT.LIVE_AGENT;
            default:
                return { text: MENUS.TUBEL_STAN };
        }
    }

    // Level 3: STAN_KELAS → konten detail
    if (subState === 'STAN_KELAS') {
        switch (input) {
            case '1': return CONTENT.TUBEL_STAN_1;
            case '2': return CONTENT.TUBEL_STAN_2;
            case '3': return CONTENT.TUBEL_STAN_3;
            case '4': return CONTENT.TUBEL_STAN_4;
            case '5': return CONTENT.LIVE_AGENT;
            default:  return { text: MENUS.TUBEL_STAN_KELAS };
        }
    }

    // Level 3: STAN_TO → belum tersedia
    if (subState === 'STAN_TO') {
        switch (input) {
            case '3': return CONTENT.LIVE_AGENT;
            default:  return { text: MENUS.TUBEL_STAN_TO };
        }
    }

    // Level 2: BPKP → belum tersedia
    if (subState === 'BPKP') {
        return { text: MENUS.TUBEL_BPKP };
    }

    return { text: MENUS.TUBEL };
}

