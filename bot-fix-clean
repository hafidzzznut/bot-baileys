// ===================================================
// ===== ADMIN PAUSE MANAGEMENT =====
// ===================================================

function isUserPausedByAdmin(userId) {
    if (!adminPausedUsers.has(userId)) return false;
    const pauseData = adminPausedUsers.get(userId);
    const now = Date.now();
    if (now >= pauseData.pauseUntil) {
        adminPausedUsers.delete(userId);
        console.log(`⏰ Admin pause expired for user: ${userId}`);
        return false;
    }
    return true;
}

function pauseUserByAdmin(userId) {
    const pauseUntil = Date.now() + CONFIG.adminPauseDuration;
    adminPausedUsers.set(userId, { pauseUntil, notificationSent: false });
    const pauseMinutes = CONFIG.adminPauseDuration / (60 * 1000);
    console.log(`⏸️  Bot PAUSED for user ${userId} for ${pauseMinutes} minutes (admin initiated)`);
}

function unpauseUser(userId) {
    if (adminPausedUsers.has(userId)) {
        adminPausedUsers.delete(userId);
        conversationInitiators.delete(userId);
        console.log(`▶️  Bot RESUMED for user: ${userId}`);
    }
}

setInterval(() => {
    const now = Date.now();
    for (const [userId, pauseData] of adminPausedUsers.entries()) {
        if (now >= pauseData.pauseUntil) {
            adminPausedUsers.delete(userId);
            conversationInitiators.delete(userId);
            console.log(`⏰ Admin pause auto-expired for user: ${userId}`);
        }
    }
}, 5 * 60 * 1000);

// ===================================================
// ===== STATE MANAGEMENT FUNCTIONS =====
// ===================================================

function getUserState(userId) {
    if (!userStates.has(userId)) {
        userStates.set(userId, {
            state: STATE.MAIN_MENU,
            subState: null,
            history: [],           // stack history untuk back navigation
            lastActivity: Date.now()
        });
    }
    return userStates.get(userId);
}

function setUserState(userId, newState, subState = null) {
    const current = getUserState(userId);

    // Simpan posisi saat ini ke history sebelum pindah
    current.history.push({ state: current.state, subState: current.subState });
    // Batasi history maks 10 langkah
    if (current.history.length > 10) current.history.shift();

    current.state        = newState;
    current.subState     = subState;
    current.lastActivity = Date.now();
    userStates.set(userId, current);

    console.log(`🔄 State: ${newState}${subState ? ' / ' + subState : ''} [history: ${current.history.length}]`);
}

function resetUserState(userId) {
    userStates.set(userId, {
        state: STATE.MAIN_MENU,
        subState: null,
        history: [],
        lastActivity: Date.now()
    });
}

// ── Kembali ke state sebelumnya (history pop) ─────────────────────
function goBack(userId) {
    const current = getUserState(userId);

    if (!current.history || current.history.length === 0) {
        resetUserState(userId);
        return { text: MENUS.MAIN, deactivateLiveAgent: true };
    }

    const prev = current.history.pop();
    current.state        = prev.state;
    current.subState     = prev.subState;
    current.lastActivity = Date.now();
    userStates.set(userId, current);

    console.log(`⬅️  Go BACK: ${prev.state}${prev.subState ? ' / ' + prev.subState : ''} [history: ${current.history.length}]`);

    return getMenuForState(prev.state, prev.subState);
}

// ── Mapping state → teks menu ─────────────────────────────────────
function getMenuForState(state, subState) {
    if (state === STATE.MAIN_MENU)    return { text: MENUS.MAIN };
    if (state === STATE.UPKP_MENU)    return { text: MENUS.UPKP };
    if (state === STATE.SAK_MENU)     return { text: MENUS.SAK };
    if (state === STATE.OTHER_MENU)   return { text: MENUS.OTHER };
    if (state === STATE.TO_MENU)      return { text: MENUS.TO_GRATIS };
    if (state === STATE.GARANSI_MENU) return { text: MENUS.GARANSI };

    if (state === STATE.TUBEL_MENU) {
        if (!subState)                 return { text: MENUS.TUBEL };
        if (subState === 'STAN')       return { text: MENUS.TUBEL_STAN };
        if (subState === 'STAN_KELAS') return { text: MENUS.TUBEL_STAN_KELAS };
        if (subState === 'STAN_TO')    return { text: MENUS.TUBEL_STAN_TO };
        if (subState === 'BPKP')       return { text: MENUS.TUBEL_BPKP };
        return { text: MENUS.TUBEL };
    }

    if (state === STATE.S2_MENU) {
        if (!subState)                  return { text: MENUS.S2 };
        if (subState === 'MINTS')       return { text: MENUS.S2_MINTS };
        if (subState === 'MINTS_KELAS') return { text: MENUS.S2_MINTS_KELAS };
        if (subState === 'MINTS_TO')    return { text: MENUS.S2_MINTS_TO };
        if (subState === 'LPDP')        return { text: MENUS.S2_LPDP };
        return { text: MENUS.S2 };
    }

    return { text: MENUS.MAIN };
}

// ===================================================
// ===== MESSAGE ROUTING LOGIC =====
// ===================================================

function routeMessage(userId, messageText) {
    const userState = getUserState(userId);
    const input = messageText.toLowerCase().trim();

    // ── 0  → kembali ke menu UTAMA ───────────────
    if (input === '0' || input === 'menu') {
        resetUserState(userId);
        return { text: MENUS.MAIN, deactivateLiveAgent: true };
    }

    // ── 00 → kembali ke menu SEBELUMNYA ──────────
    if (input === '00' || input === 'kembali' || input === 'back') {
        return goBack(userId);
    }

    // ── Live Agent (global shortcut) ──────────────
    if (
        input === '8' || input === 'live agent' || input === 'agent' ||
        input === 'admin' || input.includes('hubungi admin') ||
        input.includes('bicara dengan admin')
    ) {
        return CONTENT.LIVE_AGENT;
    }

    // ── Greeting → Main Menu ──────────────────────
    const greetings = [
        'halo','hai','hallo','hello','info','p','pagi',
        'siang','sore','malam','nanya','ada','apakah',
        'gimana','tes','berapa','dimana','daftar',
        'kelas','rencana','kapan'
    ];
    if (greetings.includes(input)) {
        resetUserState(userId);
        return { text: MENUS.MAIN };
    }

    // ── State-based routing ───────────────────────
    switch (userState.state) {
        case STATE.MAIN_MENU:    return handleMainMenu(userId, input);
        case STATE.TUBEL_MENU:   return handleTubelMenu(userId, input, userState.subState);
        case STATE.UPKP_MENU:    return handleUpkpMenu(userId, input);
        case STATE.SAK_MENU:     return handleSakMenu(userId, input);
        case STATE.S2_MENU:      return handleS2Menu(userId, input, userState.subState);
        case STATE.OTHER_MENU:   return handleOtherMenu(userId, input);
        case STATE.TO_MENU:      return handleToGratisMenu(userId, input);
        case STATE.GARANSI_MENU: return handleGaransiMenu(userId, input);
        default:
            resetUserState(userId);
            return FALLBACK;
    }
}

